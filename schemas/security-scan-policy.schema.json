{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.test/schemas/security-scan-policy.schema.json",
  "title": "Security scan policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "scans", "thresholds", "reporting"],
  "properties": {
    "version": {
      "const": 1
    },
    "scans": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/scan"
      },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "const": "sast"
              }
            }
          }
        },
        {
          "contains": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "const": "dependency"
              }
            }
          }
        },
        {
          "contains": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "const": "secret"
              }
            }
          }
        }
      ]
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maximumCriticalFindings", "maximumHighFindings"],
      "properties": {
        "maximumCriticalFindings": {
          "const": 0
        },
        "maximumHighFindings": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        }
      }
    },
    "reporting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "path", "retentionDays"],
      "properties": {
        "format": {
          "enum": ["json", "html"]
        },
        "path": {
          "type": "string",
          "pattern": "^(?!.*\\.\\.)[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"
        },
        "retentionDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30
        }
      }
    }
  },
  "$defs": {
    "scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "required", "blockOnSeverities"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "type": {
          "enum": ["sast", "dependency", "secret"]
        },
        "required": {
          "const": true
        },
        "blockOnSeverities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["critical", "high", "medium", "low"]
          },
          "contains": {
            "const": "critical"
          }
        }
      }
    }
  }
}
