{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.test/schemas/kubernetes-regression-cronjob.schema.json",
  "title": "Kubernetes regression-test CronJob",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "batch/v1" },
    "kind": { "const": "CronJob" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schedule",
        "concurrencyPolicy",
        "successfulJobsHistoryLimit",
        "failedJobsHistoryLimit",
        "jobTemplate"
      ],
      "properties": {
        "schedule": {
          "type": "string",
          "pattern": "^\\S+\\s+\\S+\\s+\\S+\\s+\\S+\\s+\\S+$"
        },
        "concurrencyPolicy": { "const": "Forbid" },
        "successfulJobsHistoryLimit": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "failedJobsHistoryLimit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "jobTemplate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["spec"],
          "properties": {
            "spec": {
              "type": "object",
              "additionalProperties": false,
              "required": ["backoffLimit", "template"],
              "properties": {
                "backoffLimit": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 3
                },
                "template": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["metadata", "spec"],
                  "properties": {
                    "metadata": { "$ref": "#/$defs/metadata" },
                    "spec": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["restartPolicy", "containers"],
                      "properties": {
                        "restartPolicy": { "const": "Never" },
                        "containers": {
                          "type": "array",
                          "minItems": 1,
                          "items": { "$ref": "#/$defs/container" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["labels"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "labels": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "minLength": 1 },
          "additionalProperties": { "type": "string", "minLength": 1 }
        }
      }
    },
    "container": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "image", "imagePullPolicy", "env", "command"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "image": {
          "type": "string",
          "pattern": "^[^\\s:]+(?:/[^\\s:]+)*:[^\\s:]+$"
        },
        "imagePullPolicy": {
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "env": {
          "type": "array",
          "contains": {
            "type": "object",
            "required": ["name", "value"],
            "properties": {
              "name": { "const": "BASE_URL" },
              "value": {
                "type": "string",
                "pattern": "^https?://[^\\s]+$"
              }
            }
          }
        },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
