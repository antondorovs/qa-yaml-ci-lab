{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.test/schemas/qa-test-plan.schema.json",
  "title": "QA test plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "suite", "owner", "environment", "tests"],
  "properties": {
    "version": {
      "const": 1
    },
    "suite": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "minLength": 1
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "priority",
          "type",
          "tags",
          "steps",
          "expected"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9]+-[0-9]{3,}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "enum": ["critical", "high", "medium", "low"]
          },
          "type": {
            "enum": ["smoke", "regression", "api", "ui"]
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "expected": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
