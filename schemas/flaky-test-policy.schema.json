{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.test/schemas/flaky-test-policy.schema.json",
  "title": "QA flaky-test policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "rerun", "quarantine"],
  "properties": {
    "version": {
      "const": 1
    },
    "rerun": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxAttempts", "onlyOn"],
      "properties": {
        "maxAttempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "onlyOn": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["timeout", "network", "browser-crash"]
          }
        }
      }
    },
    "quarantine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxDays", "requireOwner", "requireIssue", "failOnExpired"],
      "properties": {
        "maxDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30
        },
        "requireOwner": {
          "const": true
        },
        "requireIssue": {
          "const": true
        },
        "failOnExpired": {
          "const": true
        }
      }
    }
  }
}
