{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.test/schemas/pipeline-stages.schema.json",
  "title": "QA pipeline stages",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "owner", "stages"],
  "properties": {
    "version": {
      "const": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "stages": {
      "type": "array",
      "minItems": 4,
      "allOf": [
        {
          "contains": {
            "$ref": "#/$defs/qualityStage"
          }
        },
        {
          "contains": {
            "$ref": "#/$defs/smokeStage"
          }
        },
        {
          "contains": {
            "$ref": "#/$defs/regressionStage"
          }
        },
        {
          "contains": {
            "$ref": "#/$defs/reportStage"
          }
        }
      ],
      "items": {
        "$ref": "#/$defs/stage"
      }
    }
  },
  "$defs": {
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "purpose", "jobs", "required"],
      "properties": {
        "name": {
          "enum": ["quality", "smoke", "regression", "report"]
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "jobs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "qualityStage": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "const": "quality"
        }
      }
    },
    "smokeStage": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "const": "smoke"
        }
      }
    },
    "regressionStage": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "const": "regression"
        }
      }
    },
    "reportStage": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "const": "report"
        }
      }
    }
  }
}
