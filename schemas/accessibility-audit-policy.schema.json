{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.test/schemas/accessibility-audit-policy.schema.json",
  "title": "Accessibility audit policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "standard", "checks", "thresholds", "reporting"],
  "properties": {
    "version": {
      "const": 1
    },
    "standard": {
      "const": "wcag-2.2-aa"
    },
    "checks": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/check"
      },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "const": "keyboard-navigation"
              }
            }
          }
        },
        {
          "contains": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "const": "color-contrast"
              }
            }
          }
        },
        {
          "contains": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "const": "aria-labels"
              }
            }
          }
        }
      ]
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criticalViolations", "seriousViolations"],
      "properties": {
        "criticalViolations": {
          "const": 0
        },
        "seriousViolations": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        }
      }
    },
    "reporting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "path", "retentionDays"],
      "properties": {
        "format": {
          "enum": ["html", "json"]
        },
        "path": {
          "type": "string",
          "pattern": "^(?!.*\\.\\.)[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"
        },
        "retentionDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30
        }
      }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "severity", "requiredSuites"],
      "properties": {
        "name": {
          "enum": ["keyboard-navigation", "color-contrast", "aria-labels"]
        },
        "severity": {
          "enum": ["critical", "serious", "moderate"]
        },
        "requiredSuites": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["smoke", "regression", "e2e"]
          }
        }
      }
    }
  }
}
