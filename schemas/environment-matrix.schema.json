{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.test/schemas/environment-matrix.schema.json",
  "title": "Environment variable matrix",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "owner", "environments"],
  "properties": {
    "version": {
      "const": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "environments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "variables"],
        "properties": {
          "name": {
            "enum": ["staging", "production"]
          },
          "variables": {
            "type": "array",
            "minItems": 1,
            "contains": {
              "type": "object",
              "required": ["name", "value"],
              "properties": {
                "name": {
                  "const": "BASE_URL"
                },
                "value": {
                  "type": "string",
                  "pattern": "^https?://[^\\s]+$"
                }
              }
            },
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "value", "scope", "required"],
              "properties": {
                "name": {
                  "type": "string",
                  "pattern": "^[A-Z][A-Z0-9_]*$"
                },
                "value": {
                  "type": "string",
                  "minLength": 1
                },
                "scope": {
                  "enum": ["runtime", "reporting", "secret-reference"]
                },
                "required": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      }
    }
  }
}
